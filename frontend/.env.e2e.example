# Frontend points to gateway
VITE_API_BASE_URL=http://localhost:8080

# Mandatory: run real backend in E2E gate suite
VITE_USE_MOCK_BACKEND=false

# Optional override for E2E credentials
E2E_PATIENT_EMAIL=patient1@clinic.com
E2E_DOCTOR_EMAIL=dr.sarah@clinic.com
E2E_ADMIN_EMAIL=admin@clinic.com
E2E_PASSWORD=password

# Optional: DB verification for E2E (enabled by default)
E2E_VERIFY_DB=true
E2E_DB_HOST=127.0.0.1
E2E_DB_USER=postgres
E2E_DB_PASSWORD=postgres
E2E_USER_DB_PORT=5433
E2E_USER_DB_NAME=user_service_db
E2E_APPOINTMENT_DB_PORT=5434
E2E_APPOINTMENT_DB_NAME=appointment_service_db
E2E_CONSULTATION_DB_PORT=5436
E2E_CONSULTATION_DB_NAME=consultation_service_db
