{
  "name": "clinic-booking-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:contracts": "vitest --run src/api/contracts/gatewayCoverage.test.js src/api/endpointRegistry.test.js",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e:prepare": "bash ./scripts/e2e-prepare.sh",
    "test:e2e:preflight": "node ./scripts/e2e-preflight.mjs",
    "test:e2e:smoke": "playwright test tests/e2e/specs/public-routes.spec.js tests/e2e/specs/cross-role-authorization.spec.js tests/e2e/specs/negative-and-resilience.spec.js",
    "test:e2e:critical": "playwright test tests/e2e/specs/patient-exhaustive.spec.js tests/e2e/specs/doctor-exhaustive.spec.js tests/e2e/specs/admin-exhaustive.spec.js",
    "test:e2e:feature-contract": "playwright test tests/e2e/specs/patient-feature-contract.spec.js tests/e2e/specs/doctor-feature-contract.spec.js tests/e2e/specs/admin-feature-contract.spec.js tests/e2e/specs/auth-and-profile-integration.spec.js",
    "test:e2e:ui:non-payment": "E2E_SKIP_PAYMENT_CASES=true playwright test tests/e2e/specs/auth-flows.spec.js tests/e2e/specs/public-routes.spec.js tests/e2e/specs/cross-role-authorization.spec.js tests/e2e/specs/negative-and-resilience.spec.js tests/e2e/specs/auth-and-profile-integration.spec.js tests/e2e/specs/patient-exhaustive.spec.js tests/e2e/specs/doctor-exhaustive.spec.js tests/e2e/specs/admin-exhaustive.spec.js tests/e2e/specs/patient-feature-contract.spec.js tests/e2e/specs/doctor-feature-contract.spec.js tests/e2e/specs/admin-feature-contract.spec.js",
    "test:e2e:sheet:generate": "node ./scripts/generate-sheet-playwright-specs.mjs",
    "test:e2e:sheet": "RUN_SHEET_GENERATED=true playwright test -c playwright.sheet.config.js",
    "test:e2e:sheet:list": "RUN_SHEET_GENERATED=true playwright test --list -c playwright.sheet.config.js",
    "test:e2e:sheet:fail:generate": "node ./scripts/generate-fail-sheet-specs.mjs",
    "test:e2e:sheet:fail": "RUN_SHEET_FAIL_GENERATED=true playwright test -c playwright.sheet.fail.config.js",
    "test:e2e": "playwright test",
    "test:e2e:ci": "npm run test:e2e:prepare && npm run test:e2e",
    "test:e2e:report": "playwright show-report playwright-report"
  },
  "dependencies": {
    "@stomp/stompjs": "^7.2.1",
    "axios": "^1.13.2",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "file-saver": "^2.0.5",
    "framer-motion": "^11.0.5",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0",
    "sockjs-client": "^1.6.1",
    "tailwind-merge": "^2.2.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^1.1.0",
    "autoprefixer": "^10.4.17",
    "bcryptjs": "^3.0.3",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^23.0.1",
    "pg": "^8.19.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "vitest": "^1.1.0"
  }
}
